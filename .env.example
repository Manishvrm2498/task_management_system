MYSQL_ROOT_PASSWORD=change-me-root-password
MYSQL_DATABASE=task_db
DOCKER_PLATFORM=linux/amd64
MYSQL_PORT=3307
BACKEND_PORT=8080
FRONTEND_PORT=80
JWT_KEY=change-me-to-a-long-random-jwt-secret-at-least-32-bytes
OTP_EXPIRY_MINUTES=10
OTP_DELIVERY_REQUIRED=false
SPRING_MAIL_HOST=smtp.gmail.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=your-email@example.com
SPRING_MAIL_PASSWORD=your-email-app-password
SPRING_MAIL_FROM=your-verified-sender@example.com
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true
SPRING_MAIL_CONNECTION_TIMEOUT=5000
SPRING_MAIL_TIMEOUT=10000
SPRING_MAIL_WRITE_TIMEOUT=10000
SENDGRID_API_KEY=your-sendgrid-api-key
SENDGRID_FROM_EMAIL=your-verified-sender@example.com
SENDGRID_FROM_NAME=Task Management System
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+10000000000
